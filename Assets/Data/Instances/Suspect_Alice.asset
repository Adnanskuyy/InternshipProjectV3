  m_Name: Suspect_Alice
  m_EditorClassIdentifier: Assembly-CSharp::InvestigationGame.Data.SuspectData
  SuspectName: Alice
  PolaroidSprite: {fileID: 5329720113751402079, guid: 5e6ba35648e33ed458b02472d340274a, type: 3}
  PhysicalCharacteristics:
    Description: Sering mengatupkan rahang dengan kuat atau mengunyah bibir bagian
      dalam secara tidak sadar. Matanya sering tampak berkaca-kaca namun pupilnya
      tetap kecil meski di ruangan redup.
    Image: {fileID: -4670967925120817369, guid: 8aa1e9cd3b15cc041a779599da3c7f33, type: 3}
  Behavior:
    Description: Mengalami perubahan suasana hati yang ekstrem; bisa sangat ramah
      lalu tiba-tiba menjadi sangat defensif atau paranoid tanpa alasan jelas. Sering
      meminta izin ke kamar mandi dalam durasi yang lama.
    Image: {fileID: -4695704528184898611, guid: b8844114cf5a075478d14ec12adf957d, type: 3}
  Rumors: Tetangga sering mendengar suara gaduh dari rumahnya pada jam-jam ganjil,
    dan ia sering terlihat menggadaikan barang-barang pribadi yang berharga.
  IsUser: 1
  hasBeenTested: 0
